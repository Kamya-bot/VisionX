# ============================================================
# VisionX — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=visionx
POSTGRES_USER=visionx
POSTGRES_PASSWORD=choose_a_strong_password_here
POSTGRES_PORT=5432

# ── Backend ─────────────────────────────────────────────────
BACKEND_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS — comma-separated allowed origins ──────────────────
CORS_ORIGINS=http://localhost,http://localhost:80,https://yourdomain.com

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_PORT=80

# The public URL of your backend API (what the browser calls)
# Local dev:   http://localhost:8000
# Production:  https://api.yourdomain.com
VISIONX_API_URL=http://localhost:8000
